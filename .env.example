# ============================================================
# Environment
# ============================================================

CHAT_ENV=local
CHAT_LOG_LEVEL=debug

# ============================================================
# Native PostgreSQL
# ============================================================

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55432
POSTGRES_USER=chat
POSTGRES_PASSWORD=change-me
POSTGRES_DATABASE=chat

# ============================================================
# Native Valkey / Redis-compatible cache
# ============================================================

VALKEY_HOST=127.0.0.1
VALKEY_PORT=56379

# ============================================================
# Native MinIO
# ============================================================

MINIO_HOST=127.0.0.1
MINIO_API_PORT=59000
MINIO_CONSOLE_PORT=59001
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me

# ============================================================
# Identity / account services
# ============================================================

AUTH_SERVICE_ADDR=127.0.0.1:61001
ACCOUNT_SERVICE_ADDR=127.0.0.1:61002
DEVICE_SERVICE_ADDR=127.0.0.1:61003
USERNAME_SERVICE_ADDR=127.0.0.1:61004
PROFILE_SERVICE_ADDR=127.0.0.1:61005

# ============================================================
# Cryptographic directory services
# ============================================================

KEY_DIRECTORY_ADDR=127.0.0.1:61101
KEY_TRANSPARENCY_ADDR=127.0.0.1:61102
CONTACT_DISCOVERY_ADDR=127.0.0.1:61103

# ============================================================
# Privacy routing
# ============================================================

INGRESS_RELAY_ADDR=127.0.0.1:62001
MAILBOX_GATEWAY_ADDR=127.0.0.1:62002
MAILBOX_STORE_ADDR=127.0.0.1:62003
OBJECT_GATEWAY_ADDR=127.0.0.1:62004

# ============================================================
# Group / OHTTP
# ============================================================

GROUP_SERVICE_ADDR=127.0.0.1:63001
OHTTP_RELAY_ADDR=127.0.0.1:63002
OHTTP_GATEWAY_ADDR=127.0.0.1:63003

# ============================================================
# Auxiliary services
# ============================================================

PUSH_ROUTER_ADDR=127.0.0.1:64001
BACKUP_SERVICE_ADDR=127.0.0.1:64002
CONFIG_SERVICE_ADDR=127.0.0.1:64003

CALL_SIGNALING_ADDR=127.0.0.1:65001
LINK_PREVIEW_SERVICE_ADDR=127.0.0.1:65002
ABUSE_CONTROL_ADDR=127.0.0.1:65003
DIAGNOSTIC_INGEST_ADDR=127.0.0.1:65004
